# Python
__pycache__/
*.pyc

# Virtualenvs
.venv/
snapshot/**/.venv/

# Logs
*.log
*.out

# Images / generated reports
*.png

# Archives / backups
*.tar.gz
*.bak.*
*.bak

# Databases and SQLite sidecars
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Optional: keep only code/config in snapshot
snapshot/timing/reports/

# Keep empty tracked runtime dirs
data/*
!data/.gitkeep
plots/*
!plots/.gitkeep
backups/*
!backups/.gitkeep

# Editor / OS junk
.DS_Store
Thumbs.db
.vscode/
.idea/

# Teensy / Arduino build artifacts
*.elf
*.hex
*.bin
